{
  "diagnostic.errorSign": "✘",
  "diagnostic.warningSign": "!",
  "diagnostic.infoSign": "?",
  "solargraph.formatting": true,
  "solargraph.diagnostics": true,
  "elixir.pathToElixirLS": "/opt/homebrew/bin/elixir-ls",
  "Lua.format.defaultConfig":{
    "indent_style":"space",
    "indent_size":"2"
